<Sysmon schemaversion="4.30">
	<EventFiltering>
		<RuleGroup name="" groupRelation="or">
			<RegistryEvent onmatch="exclude">
				<Rule groupRelation="and">
				  <Image condition="image">svchost.exe</Image>
				  <TargetObject condition="begin with">HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\CapabilityAccessManager\ConsentStore\location\NonPackaged\C:#Program Files (x86)#Lenovo#VantageService</TargetObject>
				</Rule>
			</RegistryEvent>
		</RuleGroup>
	</EventFiltering>
</Sysmon>
